# From developers.tiktok.com → your app → Keys and tokens
TIKTOK_CLIENT_KEY=your_client_key_here
TIKTOK_CLIENT_SECRET=your_client_secret_here

# Privacy level for posted videos:
#   PUBLIC_TO_EVERYONE | FOLLOWER_OF_CREATOR | MUTUAL_FOLLOW_FRIENDS | SELF_ONLY
TIKTOK_PRIVACY_LEVEL=PUBLIC_TO_EVERYONE

# Optional: web dashboard port (default 3000)
# PORT=3000

# ── Tokens are managed automatically by "npm run auth" ──
# Do not add TIKTOK_ACCESS_TOKEN or TIKTOK_REFRESH_TOKEN here.
# They are saved to tokens.json (gitignored) after you run auth.
